rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, subscription_plan, subscription_status, country, createdAt
    //
    // Collection: anime
    // Fields: title, description, genre, posterUrl, createdAt
    //
    // Collection: anime/{animeId}/episodes
    // Fields: animeId, title, videoUrl, accessType, order
    //
    // Collection: plans
    // Fields: name, price, duration, benefits
    //
    // Collection: purchaseRequests
    // Fields: userId, userName, planId, planName, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email in ["mrkhatab112@gmail.com", "admin@rex.com"] && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'country']) &&
             data.role in ['user', 'admin'] &&
             data.subscription_status in ['active', 'pending', 'rejected', 'none'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && 
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.uid == resource.data.uid);
    }

    match /anime/{animeId} {
      allow read: if true; // Everyone can watch/browse
      allow write: if isAdmin();
      
      match /episodes/{episodeId} {
        allow read: if true; // Everyone can see list, access logic handled in app
        allow write: if isAdmin();
      }
    }

    match /plans/{planId} {
      allow read: if true; // Everyone can see plans
      allow write: if isAdmin();
    }

    match /purchaseRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
