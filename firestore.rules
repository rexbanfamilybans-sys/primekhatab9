rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, subscription_plan, subscription_status, country, createdAt
    //
    // Collection: anime
    // Fields: title, description, genre, posterUrl, createdAt
    //
    // Collection: anime/{animeId}/episodes
    // Fields: animeId, title, videoUrl, accessType, order
    //
    // Collection: plans
    // Fields: name, price, duration, benefits
    //
    // Collection: purchaseRequests
    // Fields: userId, userName, planId, planName, status, createdAt
    //
    // Collection: redeemCodes
    // Fields: code, planId, planName, maxUses, usedCount, usedBy, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["mrkhatab112@gmail.com", "admin@rex.com"] ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'country']) &&
             data.role in ['user', 'admin'] &&
             data.subscription_status in ['active', 'pending', 'rejected', 'none'];
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data)) || isAdmin();
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.subscription_status == resource.data.subscription_status &&
        request.resource.data.subscription_plan == resource.data.subscription_plan
      );
      allow delete: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /episodes/{episodeId} {
        allow read: if true;
        allow write: if isAdmin();

        match /likes/{userId} {
          allow read: if true;
          allow write: if isAuthenticated() && request.auth.uid == userId;
        }

        match /comments/{commentId} {
          allow read: if true;
          allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
          allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        }
      }
    }

    match /plans/{planId} {
      allow read: if true; // Everyone can see plans
      allow write: if isAdmin();
    }

    match /purchaseRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /redeemCodes/{codeId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.usedCount == resource.data.usedCount + 1 &&
        request.resource.data.usedBy.size() == resource.data.usedBy.size() + 1 &&
        request.resource.data.usedBy.hasAll(resource.data.usedBy) &&
        request.auth.uid in request.resource.data.usedBy &&
        !(request.auth.uid in resource.data.usedBy) &&
        request.resource.data.usedCount <= resource.data.maxUses
      );
    }
  }
}
